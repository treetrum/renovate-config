{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended", ":semanticCommitTypeAll(deps)", ":semanticCommitScopeDisabled"],
  "semanticCommits": "enabled",
  "labels": ["dependencies"],
  "reviewers": ["@treetrum"],
  "packageRules": [
    {
      "matchManagers": ["npm"],
      "matchDepTypes": ["dependencies", "devDependencies"],
      "rangeStrategy": "pin"
    },
    {
      "matchUpdateTypes": ["patch"],
      "automerge": true
    },
    {
      "matchPackageNames": ["oxfmt", "oxlint", "oxlint-tsgolint"],
      "automerge": true
    }
  ]
}
