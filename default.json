{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "semanticCommits": "enabled",
  "labels": ["dependencies"],
  "minimumReleaseAge": "1 day",
  "packageRules": [
    {
      "matchManagers": ["npm"],
      "matchDepTypes": ["dependencies", "devDependencies"],
      "rangeStrategy": "pin"
    },
    {
      "matchPackageNames": ["*"],
      "automerge": false,
      "reviewers": ["@treetrum"]
    },
    {
      "matchManagers": ["npm"],
      "matchDepTypes": ["dependencies"],
      "matchUpdateTypes": ["patch"],
      "automerge": true,
      "reviewers": []
    },
    {
      "matchManagers": ["npm"],
      "matchDepTypes": ["devDependencies"],
      "matchUpdateTypes": ["patch", "minor"],
      "automerge": true,
      "reviewers": []
    },
    {
      "groupName": "oxc monorepo",
      "matchPackageNames": ["oxlint", "oxfmt", "oxlint-tsgo"],
      "automerge": true,
      "reviewers": []
    }
  ]
}
